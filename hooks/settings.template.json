{
  "_comment": "omni_powers hooks 配置模板。opinit 安装时合并到 ~/.claude/settings.json（或项目 .claude/settings.json）。",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit|Bash",
        "hooks": [
          { "type": "command", "command": "bash $OP_HOME/hooks/pre_tool_use.sh" }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          { "type": "command", "command": "bash $OP_HOME/hooks/post_tool_use.sh" }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          { "type": "command", "command": "bash $OP_HOME/hooks/stop.sh" }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          { "type": "command", "command": "bash $OP_HOME/hooks/session_start.sh" }
        ]
      }
    ]
  }
}
