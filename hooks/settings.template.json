{
  "_comment": "omni_powers hooks 配置模板。opinit 安装时合并到 ~/.claude/settings.json。hook command 走 polyglot wrapper（run-hook.cmd），macOS/Linux 默认用 bash 调 wrapper；Windows 由 opinit_register_hooks.sh 改写为直接 .cmd 绝对路径。参数不带 .sh，wrapper 内部补 .sh。",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit|Bash",
        "hooks": [
          { "type": "command", "command": "bash \"$OP_HOME/hooks/run-hook.cmd\" pre_tool_use" }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          { "type": "command", "command": "bash \"$OP_HOME/hooks/run-hook.cmd\" post_tool_use" }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "op-implementer",
        "hooks": [
          { "type": "command", "command": "bash \"$OP_HOME/hooks/run-hook.cmd\" stop" }
        ]
      }
    ]
  }
}
