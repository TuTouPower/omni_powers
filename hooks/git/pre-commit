#!/usr/bin/env bash
# git pre-commit hook（heavy 专属，lite 不注册）
# 作用：spec 写保护——approved/in_progress 状态的生效规格不允许直接 commit
#       （走 §5.2 spec 变更子流程：人批 → leader 解锁脚本临时解保护 → commit → 恢复）
# 注：e2e/** 不在此拦（leader 合法提交也要过 pre-commit），e2e 校验在 commit-msg（trailer）
# 注：本 hook 在 git 层，绕过 Claude hook 对 subagent 失效问题（design §0.2 / op_decisions D18）

set -uo pipefail

repo_root="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
op_paths_helper="$(git rev-parse --git-path hooks 2>/dev/null)/op_paths.sh"
if [ -f "$op_paths_helper" ]; then
    source "$op_paths_helper"
elif [ -n "${OP_HOME:-}" ] && [ -f "$OP_HOME/scripts/op_paths.sh" ]; then
    source "$OP_HOME/scripts/op_paths.sh"
else
    echo "[git hook] FATAL: op_paths.sh 缺失，重跑 /opinit" >&2
    exit 1
fi
op_load_paths "" "$repo_root" || exit 1

against="$(git rev-parse --verify HEAD >/dev/null 2>&1 && echo HEAD || echo "$(git hash-object -t tree /dev/null)")"

blocked=0
while IFS= read -r -d '' path; do
    [ -n "$path" ] || continue
    case "$path" in
        $OP_DOCS_DIR/op_blueprint/specs/*.md|$OP_DOCS_DIR/op_blueprint/baselines/*|$OP_DOCS_DIR/op_blueprint/*.md)
            status="$(git show ":$path" 2>/dev/null | awk -F': *' '/^status:/{print $2; exit}' | tr -d '[:space:]')"
            case "$status" in
                approved|in_progress)
                    echo "[git pre-commit] BLOCKED: $path 状态=$status，受写保护。" >&2
                    echo "  改生效规格走 spec 变更子流程（design §5.2）：leader 解锁脚本临时解保护 → commit → 恢复。" >&2
                    blocked=1
                    ;;
            esac
            ;;
    esac
done < <(git diff-index --cached -z --name-only "$against")

[ "$blocked" -eq 0 ] || exit 1

# ── merge gate 硬约束（本轮改进）：有 in_progress task 且缺 merge gate 证据 → 拒 commit ──
TASKS_FILE="$OP_DOCS_DIR/op_execution/tasks_list.json"
if [ -f "$TASKS_FILE" ] && command -v jq >/dev/null 2>&1; then
    while IFS= read -r tid; do
        [ -n "$tid" ] || continue
        gate_evidence="$OP_DOCS_DIR/op_execution/tasks/$tid/.merge_gate_passed"
        if [ ! -f "$gate_evidence" ]; then
            echo "[git pre-commit] BLOCKED: task $tid in_progress 但未过 merge gate。" >&2
            echo "  必须先跑 op_merge_gate.sh $tid <task_branch> 通过后才许 commit。" >&2
            blocked=1
        fi
    done < <(jq -r '.tasks[] | select(.status=="in_progress") | .id' "$TASKS_FILE" 2>/dev/null)
fi

[ "$blocked" -eq 0 ] || exit 1
exit 0
