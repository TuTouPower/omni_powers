#!/usr/bin/env bash
# git post-receive: 本地 CI 等价物触发（design §3.3.1，heavy 专属）
#
# 用途：bare 仓库接收 push 时跑 op_ci_local.sh（被监督者控制之外执行）。
# 无 bare 仓库的单仓库项目，leader 可在 implementer 交工后直接跑 op_ci_local.sh，
# 或用 post-commit（注意 post-commit 每次 commit 触发，频率高）。
#
# 结果落 .ci-results/{sha}/，reviewer/leader 读 result.json 裁决（per-task 证据脱离被监督者控制）。
# 安全：post-receive 在服务端跑，implementer subagent 不在此进程——结果不可被 agent 篡改。

set -uo pipefail

op_home="${OP_HOME:-}"
[ -n "$op_home" ] || { echo "[post-receive] OP_HOME 未设，跳过 op_ci_local" >&2; exit 0; }

while read -r oldrev newrev refname; do
    # 跳过分支删除
    [ "$newrev" != "0000000000000000000000000000000000000000" ] || continue
    # 后台跑，不阻塞 push
    (
        cd "${GIT_REPO:-$(pwd)}" 2>/dev/null || exit 0
        git checkout -q "$newrev" 2>/dev/null || true
        OP_HEAD="$newrev" bash "$op_home/scripts/op_ci_local.sh" \
            > "$op_home/.ci-results-$newrev.stdout" 2>&1 || true
    ) &
done

wait 2>/dev/null || true
exit 0
